{
  "accentColor": "{{appsmith.theme.colors.primaryColor}}",
  "animateLoading": true,
  "borderRadius": "{{appsmith.theme.borderRadius.appBorderRadius}}",
  "bottomRow": 20,
  "boxShadow": "none",
  "defaultOptionValue": "",
  "dynamicBindingPathList": [
    {
      "key": "accentColor"
    },
    {
      "key": "borderRadius"
    },
    {
      "key": "sourceData"
    }
  ],
  "dynamicHeight": "FIXED",
  "dynamicPropertyPathList": [
    {
      "key": "sourceData"
    }
  ],
  "dynamicTriggerPathList": [
    {
      "key": "onDropdownOpen"
    },
    {
      "key": "onOptionChange"
    }
  ],
  "isDisabled": false,
  "isFilterable": true,
  "isLoading": false,
  "isRequired": false,
  "isVisible": true,
  "key": "k_sel_restr_student",
  "labelAlignment": "left",
  "labelPosition": "Top",
  "labelText": "Buscar alumno activo",
  "labelTextSize": "0.875rem",
  "labelWidth": 5,
  "leftColumn": 3,
  "maxDynamicHeight": 9000,
  "minDynamicHeight": 4,
  "minWidth": 450,
  "needsErrorInfo": false,
  "optionLabel": "label",
  "optionValue": "value",
  "parentColumnSpace": 16,
  "parentId": "0",
  "parentRowSpace": 10,
  "placeholderText": "Buscar por nombre o RUT",
  "renderMode": "CANVAS",
  "responsiveBehavior": "fill",
  "rightColumn": 32,
  "serverSideFiltering": false,
  "sourceData": "{{(() => { const rows = (get_restr_students.data && get_restr_students.data.length ? get_restr_students.data : appsmith.store.restr_students_options) || []; return rows.length ? rows.map((a) => ({ label: a.label || ((a.nombre_completo || 'Sin nombre') + ' (' + (a.rut || 'Sin RUT') + ')'), value: a.value || a.id_alumno })) : [{ label: 'Sin alumnos cargados', value: '__empty__' }]; })()}}",
  "topRow": 13,
  "type": "SELECT_WIDGET",
  "version": 1,
  "widgetId": "w_sel_restr_student",
  "widgetName": "sel_restr_student",
  "onDropdownOpen": "{{get_restr_students.run().then(() => storeValue('restr_students_options', get_restr_students.data || [])).catch((error) => showAlert('Error cargando alumnos: ' + error.message, 'error'));}}",
  "onOptionChange": "{{sel_restr_student.selectedOptionValue && sel_restr_student.selectedOptionValue !== '__empty__' ? get_student_restrictions.run() : null;}}"
}
